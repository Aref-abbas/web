---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import logo from '../assets/logo.jpg';
import roofDetail from '../assets/projects/dachreinigung-konstanz.jpg';
import roofChannel from '../assets/projects/dachrinne-vorher.jpg';
import tileRepair from '../assets/projects/dachziegel-reparatur.jpg';
import sealingBefore from '../assets/projects/abdichtung-vorher.jpg';
import sealingAfter from '../assets/projects/abdichtung-nachher.jpg';
import WhatsAppIcon from '../components/WhatsAppIcon.astro';
import RoofScene from '../components/RoofScene.astro';
import GreenhouseScene from '../components/GreenhouseScene.astro';
import BodenseeMark from '../components/BodenseeMark.astro';
import QRCode from 'qrcode';

const title = 'AR Holz- & Bautenschutz | Dach & Gebäudeschutz in Konstanz und am Bodensee';
const description = 'Holzschutz, Bautenschutz, Abdichtung, Dachservice sowie Fenster- und Gewächshausreinigung. Persönlich ausgeführt von Aref Razai – mit Sitz in Konstanz, im Einsatz in der ganzen Bodensee-Region.';
const whatsappUrl = `https://wa.me/491772156157?text=${encodeURIComponent('Hallo Herr Razai, ich möchte gerne eine unverbindliche Anfrage stellen.')}`;
const whatsappQrSvg = await QRCode.toString(whatsappUrl, {
  type: 'svg',
  margin: 1,
  color: { dark: '#171715', light: '#ffffff' },
});

const services = [
  {
    number: '01',
    title: 'Holzschutz',
    text: 'Schutz und Pflege für außenliegende Holzteile, Dachüberstände und beanspruchte Bauteile.',
    icon: '<path d="M4 18c4-1 5-5 6-12 5 1 8 4 9 8-1 4-5 6-9 4M7 20c2-5 5-8 9-10"/>',
  },
  {
    number: '02',
    title: 'Bautenschutz',
    text: 'Vorbeugender Schutz für Bauteile, Anschlüsse und sensible Bereiche rund ums Gebäude.',
    icon: '<path d="M12 3 5 6v5c0 5 3 8 7 10 4-2 7-5 7-10V6l-7-3ZM9 12l2 2 4-4"/>',
  },
  {
    number: '03',
    title: 'Abdichtungsarbeiten',
    text: 'Saubere Detailabdichtungen an Übergängen, Anschlüssen, Fugen und kleineren Schadstellen.',
    icon: '<path d="M4 14c3-5 5-8 8-11 3 3 8 8 8 12a8 8 0 0 1-16 0Zm5 1 2 2 4-5"/>',
  },
  {
    number: '04',
    title: 'Mauerwerksabdichtung',
    text: 'Abdichtungen an Mauerwerk und Sockelbereichen nach vorheriger Prüfung der Situation.',
    icon: '<path d="M4 8h16M4 13h16M4 18h16M7 8v5m5 0v5m5-10v5"/>',
  },
  {
    number: '05',
    title: 'Kellerabdichtung',
    text: 'Feuchtigkeitsschutz für Keller- und erdberührte Bereiche im abgestimmten Umfang.',
    icon: '<path d="M4 20V8l8-4 8 4v12M8 20v-7h8v7M8 10h8"/>',
  },
  {
    number: '06',
    title: 'Balkonsanierung',
    text: 'Instandsetzung, Schutz und Abdichtung von Balkonflächen, Kanten und Anschlüssen.',
    icon: '<path d="M5 11h14M7 11v8m10-8v8M4 19h16M8 7h8l2 4H6l2-4Z"/>',
  },
  {
    number: '07',
    title: 'Feuchtigkeitsschutz',
    text: 'Maßnahmen gegen eindringende Feuchtigkeit – passend zu Bauteil, Nutzung und Schadenbild.',
    icon: '<path d="M12 3s6 6 6 11a6 6 0 0 1-12 0c0-5 6-11 6-11Zm-2 12c.4 1.4 1.3 2.2 3 2.4"/>',
  },
  {
    number: '08',
    title: 'Schimmelbeseitigung',
    text: 'Entfernung betroffener Stellen und Beratung zu Feuchteursachen und weiterem Vorgehen.',
    icon: '<path d="M12 12m-3 0a3 3 0 1 0 6 0 3 3 0 1 0-6 0M5 8l3 2m8 4 3 2M8 19l2-4m4-6 2-4M5 16l3-2m8-4 3-2"/>',
  },
  {
    number: '09',
    title: 'Dachabdichtungen',
    text: 'Abdichtungen an Dachflächen, Durchdringungen und Übergängen mit Blick fürs Detail.',
    icon: '<path d="M3 11.5 12 4l9 7.5M6 10v9h12v-9M9 15c1-2 2-3.2 3-4 1 1.3 2.2 2.5 3 4"/>',
  },
  {
    number: '10',
    title: 'Flachdachabdichtung',
    text: 'Prüfung und Abdichtung von Flachdachbereichen, Anschlüssen und Randzonen.',
    icon: '<path d="M4 15h16M6 15l2-7h8l2 7M8 19h8"/>',
  },
  {
    number: '11',
    title: 'Dachrinnenreinigung',
    text: 'Entfernung von Laub, Moos und Schmutz aus Dachrinnen und Ablaufbereichen.',
    icon: '<path d="M4 6h16M5 6l1.5 12h11L19 6M8 10h8M9 14h6"/>',
  },
  {
    number: '12',
    title: 'Sanierungsarbeiten',
    text: 'Kleinere Sanierungs- und Reparaturarbeiten werden transparent besprochen und ausgeführt.',
    icon: '<path d="m14 5 5 5M13 6l2-2 5 5-2 2M12 7 4 15l-1 5 5-1 8-8M5 15l4 4"/>',
  },
  {
    number: '13',
    title: 'Gewächshausreinigung',
    text: 'Glasflächen innen und außen von Hand gereinigt – auch dort, wo Reinigungsmaschinen nicht arbeiten können.',
    icon: '<path d="M12 3 4 8.5V21h16V8.5L12 3ZM4 8.5h16M8 21V9.8M16 21V9.8M4 15h16"/>',
  },
  {
    number: '14',
    title: 'Fensterreinigung',
    text: 'Reinigung von Fenstern, Glasflächen und Rahmen als ergänzender Service am Objekt.',
    icon: '<path d="M5 4h14v16H5V4Zm7 0v16M5 12h14"/>',
  },
];

const businessData = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: 'AR Holz- & Bautenschutz',
  description,
  founder: 'Aref Razai',
  url: 'https://www.ar-dach.de/',
  image: 'https://www.ar-dach.de/og-cover.jpg',
  telephone: '+49 177 2156157',
  email: 'AR.Holzschutz@web.de',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Bücklestraße 9 A',
    postalCode: '78467',
    addressLocality: 'Konstanz',
    addressRegion: 'Baden-Württemberg',
    addressCountry: 'DE',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 47.6721,
    longitude: 9.1695,
  },
  areaServed: [
    { '@type': 'City', name: 'Konstanz' },
    { '@type': 'AdministrativeArea', name: 'Bodensee-Region' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Leistungen',
    itemListElement: services.map((service) => ({
      '@type': 'Offer',
      itemOffered: { '@type': 'Service', name: service.title, description: service.text },
    })),
  },
};
---

<BaseLayout title={title} description={description}>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(businessData)} />

  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <div class="eyebrow"><span></span> Holz- &amp; Bautenschutz am Bodensee</div>
        <h1>Holzschutz, Bautenschutz und Abdichtung <em>aus Konstanz.</em></h1>
        <p class="hero-lead">Wir kümmern uns um Abdichtung, Feuchtigkeitsschutz, Schimmelbeseitigung, Dach- und Balkonsanierung – bis hin zur Reinigung von Fenstern und Gewächshäusern. Persönlich ausgeführt von Aref Razai: zu Hause in Konstanz, unterwegs in der ganzen Bodensee-Region.</p>
        <div class="hero-actions">
          <a class="button button-primary" href="tel:+491772156157">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.2 3.5 9.4 8 7.8 9.6a15.2 15.2 0 0 0 6.6 6.6l1.6-1.6 4.5 2.2-.8 3.4c-.2.8-.9 1.3-1.7 1.3A15.5 15.5 0 0 1 2.5 6c0-.8.5-1.5 1.3-1.7l3.4-.8Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg>
            Jetzt anrufen
          </a>
          <a class="button button-whatsapp" href={whatsappUrl}>
            <WhatsAppIcon />
            Per WhatsApp anfragen
          </a>
          <a class="button button-tertiary" href="mailto:AR.Holzschutz@web.de?subject=Anfrage%20über%20ar-dach.de">E-Mail</a>
        </div>
        <div class="hero-facts" aria-label="Unternehmensmerkmale">
          <div><strong>Handwerkskammer Konstanz</strong><span>eingetragener Betrieb</span></div>
          <div><strong>Konstanz &amp; Bodensee</strong><span>in der ganzen Region im Einsatz</span></div>
          <div><strong>Ein Ansprechpartner</strong><span>von der Anfrage bis zur Ausführung</span></div>
        </div>
      </div>

      <div class="hero-visual">
        <div class="hero-photo hero-scene" aria-hidden="true">
          <RoofScene />
          <span class="scene-badge">
            <BodenseeMark dotColor="#fffdf9" />
            Zuhause am Bodensee
          </span>
        </div>
        <div class="owner-card">
          <Image src={logo} alt="Logo AR Holz- und Bautenschutz" width={66} height={60} format="webp" quality={85} />
          <div><span>Ihr Ansprechpartner</span><strong>Aref Razai</strong></div>
        </div>
      </div>
    </div>
  </section>

  <section class="intro-band">
    <div class="container intro-band-inner">
      <p>Vom Dachfirst bis zum Keller: Wir schützen, dichten ab und pflegen – damit Ihr Gebäude trocken bleibt und gepflegt aussieht.</p>
      <a href="#leistungen">Leistungen ansehen <span aria-hidden="true">↓</span></a>
    </div>
  </section>

  <section class="section services" id="leistungen">
    <div class="container">
      <div class="section-heading split-heading">
        <div>
          <span class="section-kicker">Leistungen</span>
          <h2>Was wir für Sie übernehmen.</h2>
        </div>
        <p>Vierzehn Leistungen, ein Ansprechpartner: Diese Arbeiten übernehmen wir für Hausbesitzer, Verwaltungen und Betriebe rund um den Bodensee.</p>
      </div>
      <div class="services-grid">
        {services.map((service) => (
          <article class="service-card">
            <div class="service-top">
              <span class="service-number">{service.number}</span>
              <svg viewBox="0 0 24 24" aria-hidden="true" set:html={service.icon}></svg>
            </div>
            <h3>{service.title}</h3>
            <p>{service.text}</p>
          </article>
        ))}
      </div>
      <div class="services-followup">
        <p>Ihre Aufgabe ist nicht dabei? Rufen Sie kurz an – wir sagen Ihnen ehrlich, ob sie zu uns passt oder wer Ihnen besser weiterhilft.</p>
        <a href="tel:+491772156157">Kurz durchrufen <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="section work-showcase" id="arbeiten">
    <div class="container">
      <div class="section-heading work-heading">
        <span class="section-kicker light">Einblicke in die Arbeit</span>
        <h2>Mitten in der Arbeit.</h2>
        <p>Diese Aufnahmen stammen direkt von unseren Einsätzen an Dächern rund um den Bodensee – vom ersten Blick auf die Ausgangslage bis zur laufenden Ausführung.</p>
      </div>

      <div class="work-grid">
        <figure class="work-card work-card-large">
          <Image src={roofDetail} alt="Ziegeldach mit Moos und Ablagerungen vor der Reinigung" widths={[560, 820, 1080]} sizes="(max-width: 760px) 100vw, 60vw" format="webp" quality={80} />
          <figcaption><span>01</span><div><strong>Dachreinigung</strong><small>Ausgangslage: Moos und Ablagerungen</small></div></figcaption>
        </figure>
        <figure class="work-card">
          <Image src={roofChannel} alt="Verschmutzter Dachanschluss vor den Reinigungsarbeiten" widths={[420, 620, 800]} sizes="(max-width: 760px) 100vw, 38vw" format="webp" quality={80} />
          <figcaption><span>02</span><div><strong>Dachrinne &amp; Ränder</strong><small>Vor der Säuberung</small></div></figcaption>
        </figure>
        <figure class="work-card work-card-wide">
          <Image src={tileRepair} alt="Ziegeldach während kleiner Reparaturarbeiten" widths={[560, 820, 1080]} sizes="(max-width: 760px) 100vw, 58vw" format="webp" quality={80} />
          <figcaption><span>03</span><div><strong>Ziegelreparatur</strong><small>Während der Ausführung</small></div></figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section sealing-section">
    <div class="container sealing-grid">
      <div class="sealing-copy">
        <span class="section-kicker">Detailabdichtung</span>
        <h2>Der Unterschied steckt im Anschluss.</h2>
        <p>Ob Türanschluss, Balkon oder Kellerwand: Dicht wird es erst, wenn Untergrund, Vorbereitung und Ausführung zusammenpassen. Diese Aufnahmen zeigen eine von uns ausgeführte Detailabdichtung.</p>
        <ul class="check-list">
          <li><span>✓</span> Untergrund und Anschluss prüfen</li>
          <li><span>✓</span> Arbeitsbereich sorgfältig vorbereiten</li>
          <li><span>✓</span> Abdichtung im Detail ausführen</li>
          <li><span>✓</span> Lösung passend zu Dach, Balkon, Keller oder Mauerwerk</li>
        </ul>
      </div>
      <div class="sealing-comparison">
        <figure>
          <Image src={sealingBefore} alt="Türanschluss während der Vorbereitung einer Abdichtung" widths={[380, 560]} sizes="(max-width: 760px) 50vw, 25vw" format="webp" quality={82} />
          <figcaption>Vorbereitung</figcaption>
        </figure>
        <figure>
          <Image src={sealingAfter} alt="Fertig ausgeführte Abdichtung an einem Türanschluss" widths={[380, 560]} sizes="(max-width: 760px) 50vw, 25vw" format="webp" quality={82} />
          <figcaption>Ausführung</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section greenhouse-section" id="gewaechshaus">
    <div class="container greenhouse-grid">
      <div class="greenhouse-visual">
        <div class="greenhouse-card" aria-hidden="true">
          <GreenhouseScene />
          <span class="scene-badge scene-badge-inset">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3 4 8.5V21h16V8.5L12 3ZM4 8.5h16M8 21V9.8M16 21V9.8" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Innen- &amp; Außenreinigung
          </span>
        </div>
      </div>
      <div class="greenhouse-copy">
        <span class="section-kicker">Spezialgebiet Glas</span>
        <h2>Gewächshäuser: klares Glas, volles Licht.</h2>
        <p>Algen, Kalk und Staub auf dem Glas kosten Ihre Pflanzen spürbar Licht. Große Anlagen werden heute maschinell gereinigt – doch viele Gewächshäuser erreichen diese Maschinen gar nicht: zu klein, zu verwinkelt oder schlicht zu alt.</p>
        <p>Genau dort kommen wir zum Einsatz. Wir reinigen Dach- und Seitenflächen von Hand, innen wie außen – gründlich und zugleich schonend zu Glas, Rahmen und Bepflanzung.</p>
        <ul class="check-list">
          <li><span>✓</span> Glasflächen innen und außen</li>
          <li><span>✓</span> Von Hand – auch dort, wo Maschinen nicht hinkommen</li>
          <li><span>✓</span> Geeignet für ältere und kleinere Gewächshäuser</li>
          <li><span>✓</span> Schonend zu Dichtungen, Rahmen und Pflanzen</li>
        </ul>
        <a class="text-link greenhouse-link" href="#kontakt">Unverbindlich anfragen <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="section process" id="ablauf">
    <div class="container">
      <div class="section-heading centered-heading">
        <span class="section-kicker">So läuft es ab</span>
        <h2>In drei Schritten zur passenden Lösung.</h2>
      </div>
      <ol class="process-grid">
        <li>
          <span class="process-step">01</span>
          <h3>Kurz melden</h3>
          <p>Rufen Sie an, senden Sie eine E-Mail oder nutzen Sie WhatsApp. Beschreiben Sie kurz, worum es geht – Fotos helfen bei der ersten Einordnung.</p>
        </li>
        <li>
          <span class="process-step">02</span>
          <h3>Arbeit abstimmen</h3>
          <p>Umfang, Zugang und nächster Schritt werden direkt mit Aref Razai besprochen.</p>
        </li>
        <li>
          <span class="process-step">03</span>
          <h3>Sauber ausführen</h3>
          <p>Die vereinbarten Arbeiten werden persönlich und nachvollziehbar umgesetzt.</p>
        </li>
      </ol>
    </div>
  </section>

  <section class="contact-section" id="kontakt">
    <div class="container contact-grid">
      <div class="contact-copy">
        <span class="section-kicker light">Direkter Kontakt</span>
        <h2>Was ist bei Ihnen zu tun?</h2>
        <p>Eine kurze Beschreibung und ein bis drei Fotos genügen für den ersten Kontakt. Aref Razai meldet sich persönlich zurück – egal, ob Sie in Konstanz oder anderswo am Bodensee zu Hause sind.</p>
        <div class="contact-actions">
          <a class="contact-action contact-action-whatsapp" href={whatsappUrl}>
            <span class="contact-icon"><WhatsAppIcon /></span>
            <span><small>Schnell &amp; unkompliziert</small><strong>Fotos per WhatsApp senden</strong></span>
            <span class="contact-arrow" aria-hidden="true">→</span>
          </a>
          <a class="contact-action" href="tel:+491772156157">
            <span class="contact-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7.2 3.5 9.4 8 7.8 9.6a15.2 15.2 0 0 0 6.6 6.6l1.6-1.6 4.5 2.2-.8 3.4c-.2.8-.9 1.3-1.7 1.3A15.5 15.5 0 0 1 2.5 6c0-.8.5-1.5 1.3-1.7l3.4-.8Z" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg></span>
            <span><small>Telefon</small><strong>+49 177 2156157</strong></span>
          </a>
          <a class="contact-action" href="mailto:AR.Holzschutz@web.de?subject=Anfrage%20über%20ar-dach.de">
            <span class="contact-icon"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18v12H3V6Zm1 1 8 6 8-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/></svg></span>
            <span><small>E-Mail</small><strong>AR.Holzschutz@web.de</strong></span>
          </a>
        </div>
        <a class="qr-panel" href={whatsappUrl} aria-label="WhatsApp-Chat mit AR Holz- und Bautenschutz öffnen">
          <span class="qr-panel-code" role="img" aria-label="WhatsApp QR-Code für AR Holz- und Bautenschutz" set:html={whatsappQrSvg} />
          <span class="qr-panel-copy"><strong>WhatsApp direkt öffnen</strong><span>Am Smartphone antippen oder den QR-Code am Desktop scannen.</span></span>
          <span class="qr-panel-arrow" aria-hidden="true">→</span>
        </a>
      </div>
      <aside class="contact-card">
        <Image src={logo} alt="Logo AR Holz- und Bautenschutz" width={96} height={86} format="webp" quality={85} />
        <h3>AR Holz- &amp; Bautenschutz</h3>
        <p><strong>Aref Razai</strong><br />Bücklestraße 9 A<br />78467 Konstanz</p>
        <span class="registration-note">Eingetragen bei der Handwerkskammer Konstanz</span>
      </aside>
    </div>
  </section>
</BaseLayout>
