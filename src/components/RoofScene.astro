---
// Animierte Dachreinigungs-Szene: ein klar lesbares Wohnhaus mit Satteldach.
// Eine Hochdruck-Lanze fährt in Bahnen über die Dachfläche und legt die
// sauberen Ziegel frei. Reine CSS-Animation, kein JavaScript.
---

<svg
  class="roof-scene"
  viewBox="0 0 800 720"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="rs-paper" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#faf6ef" />
      <stop offset=".55" stop-color="#f0e8db" />
      <stop offset="1" stop-color="#e2d6c5" />
    </linearGradient>
    <linearGradient id="rs-dirty" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#5d554b" />
      <stop offset="1" stop-color="#443e37" />
    </linearGradient>
    <linearGradient id="rs-clean" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#d08453" />
      <stop offset=".55" stop-color="#c06f43" />
      <stop offset="1" stop-color="#a25836" />
    </linearGradient>
    <linearGradient id="rs-wall" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#efe3cf" />
      <stop offset="1" stop-color="#dcc9ab" />
    </linearGradient>
    <linearGradient id="rs-window-glow" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#f9d795" />
      <stop offset="1" stop-color="#e9ab5f" />
    </linearGradient>
    <linearGradient id="rs-skylight" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0" stop-color="#c3dde2" />
      <stop offset="1" stop-color="#61828d" />
    </linearGradient>
    <linearGradient id="rs-metal" x1="0" y1="0" x2="1" y2="0">
      <stop offset="0" stop-color="#8f8a82" />
      <stop offset="1" stop-color="#55524c" />
    </linearGradient>

    <pattern id="rs-tiles-dirty" width="76" height="88" patternUnits="userSpaceOnUse">
      <path d="M0 22q19 9 38 0t38 0M-19 66q19 9 38 0t38 0t38 0" fill="none" stroke="#332e29" stroke-opacity=".8" stroke-width="3" />
      <path d="M0 6v13M38 4v14M76 6v13M19 50v14M57 50v14" fill="none" stroke="#332e29" stroke-opacity=".5" stroke-width="2.4" />
      <path d="M0 27q19 9 38 0t38 0M-19 71q19 9 38 0t38 0t38 0" fill="none" stroke="#6e655a" stroke-opacity=".35" stroke-width="1.4" />
    </pattern>
    <pattern id="rs-tiles-clean" width="76" height="88" patternUnits="userSpaceOnUse">
      <path d="M0 22q19 9 38 0t38 0M-19 66q19 9 38 0t38 0t38 0" fill="none" stroke="#7f4227" stroke-opacity=".78" stroke-width="3" />
      <path d="M0 6v13M38 4v14M76 6v13M19 50v14M57 50v14" fill="none" stroke="#7f4227" stroke-opacity=".45" stroke-width="2.4" />
      <path d="M0 27q19 9 38 0t38 0M-19 71q19 9 38 0t38 0t38 0" fill="none" stroke="#f0b489" stroke-opacity=".55" stroke-width="1.6" />
    </pattern>

    <clipPath id="rs-roof-clip">
      <path d="M118 214 H682 L724 514 H76 Z" />
    </clipPath>

    <mask id="rs-clean-mask" maskUnits="userSpaceOnUse" x="0" y="0" width="800" height="720">
      <rect width="800" height="720" fill="#000" />
      <path
        class="rs-reveal-stroke"
        d="M158 262 H612 Q654 262 654 304 V322 Q654 364 612 364 H182 Q140 364 140 406 V424 Q140 466 182 466 H716"
        pathLength="100"
        fill="none"
        stroke="#fff"
        stroke-width="112"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
      <rect class="rs-mask-fill" width="800" height="720" fill="#fff" />
    </mask>

    <filter id="rs-soft" x="-40%" y="-40%" width="180%" height="180%">
      <feGaussianBlur stdDeviation="7" />
    </filter>
  </defs>

  <!-- Hintergrund: Papier, Raster, Sonne -->
  <rect width="800" height="720" fill="url(#rs-paper)" />
  <g stroke="#171715" stroke-opacity=".045" stroke-width="1">
    <path d="M100 0V720M200 0V720M300 0V720M400 0V720M500 0V720M600 0V720M700 0V720" />
    <path d="M0 100H800M0 200H800M0 300H800M0 400H800M0 500H800M0 600H800" />
  </g>
  <circle cx="652" cy="98" r="118" fill="#d45f2e" opacity=".07" />
  <circle cx="652" cy="98" r="74" fill="none" stroke="#d45f2e" stroke-opacity=".16" stroke-width="1.5" />

  <ellipse cx="400" cy="692" rx="342" ry="34" fill="#171715" opacity=".13" filter="url(#rs-soft)" />

  <g class="rs-house">
    <!-- Schornstein -->
    <g>
      <rect x="556" y="128" width="58" height="80" rx="3" fill="#9c5a41" />
      <path d="M563 150h44M563 172h44M563 194h44" stroke="#7f4227" stroke-opacity=".45" stroke-width="2" />
      <rect x="548" y="112" width="74" height="20" rx="5" fill="#403a34" />
      <path class="rs-smoke rs-smoke-1" d="M578 100c-6-10 4-16 0-26" fill="none" stroke="#b4aca0" stroke-opacity=".8" stroke-width="4" stroke-linecap="round" />
      <path class="rs-smoke rs-smoke-2" d="M594 96c-5-9 4-14 0-23" fill="none" stroke="#b4aca0" stroke-opacity=".6" stroke-width="3.4" stroke-linecap="round" />
    </g>

    <!-- Dachfläche: schmutzig -->
    <g clip-path="url(#rs-roof-clip)">
      <rect x="60" y="214" width="680" height="304" fill="url(#rs-dirty)" />
      <rect x="60" y="214" width="680" height="304" fill="url(#rs-tiles-dirty)" />
      <g class="rs-moss">
        <g fill="#75835a">
          <ellipse cx="188" cy="292" rx="28" ry="11" opacity=".5" />
          <ellipse cx="214" cy="303" rx="15" ry="7" opacity=".42" />
          <ellipse cx="352" cy="264" rx="22" ry="9" opacity=".44" />
          <ellipse cx="374" cy="273" rx="12" ry="6" opacity=".34" />
          <ellipse cx="500" cy="312" rx="30" ry="11" opacity=".46" />
          <ellipse cx="529" cy="303" rx="14" ry="7" opacity=".36" />
          <ellipse cx="636" cy="268" rx="19" ry="8" opacity=".4" />
        </g>
        <g fill="#67764e">
          <ellipse cx="246" cy="398" rx="30" ry="11" opacity=".5" />
          <ellipse cx="276" cy="408" rx="15" ry="7" opacity=".4" />
          <ellipse cx="420" cy="422" rx="24" ry="9" opacity=".42" />
          <ellipse cx="441" cy="413" rx="12" ry="6" opacity=".34" />
          <ellipse cx="592" cy="398" rx="22" ry="9" opacity=".46" />
          <ellipse cx="614" cy="407" rx="11" ry="5" opacity=".34" />
        </g>
        <g fill="#82906a">
          <ellipse cx="176" cy="474" rx="25" ry="9" opacity=".44" />
          <ellipse cx="201" cy="482" rx="12" ry="6" opacity=".34" />
          <ellipse cx="470" cy="482" rx="31" ry="11" opacity=".46" />
          <ellipse cx="501" cy="474" rx="14" ry="6" opacity=".36" />
          <ellipse cx="646" cy="470" rx="17" ry="7" opacity=".38" />
          <ellipse cx="322" cy="340" rx="13" ry="5" opacity=".3" />
          <ellipse cx="576" cy="344" rx="11" ry="5" opacity=".28" />
          <ellipse cx="252" cy="266" rx="11" ry="5" opacity=".26" />
        </g>
      </g>
      <path d="M150 214v304M330 214v304M510 214v304M670 214v304" stroke="#171715" stroke-opacity=".07" stroke-width="26" filter="url(#rs-soft)" />
    </g>

    <!-- Dachfläche: sauber, wird durch die Reinigungsbahn freigelegt -->
    <g class="rs-clean-layer" clip-path="url(#rs-roof-clip)" mask="url(#rs-clean-mask)">
      <rect x="60" y="214" width="680" height="304" fill="url(#rs-clean)" />
      <rect x="60" y="214" width="680" height="304" fill="url(#rs-tiles-clean)" />
      <path d="M60 250l680-22" stroke="#ffd9b8" stroke-opacity=".26" stroke-width="10" filter="url(#rs-soft)" />
    </g>

    <!-- Dachfenster -->
    <g>
      <rect x="488" y="264" width="116" height="92" rx="6" fill="#33302b" />
      <rect x="497" y="273" width="98" height="74" rx="3" fill="url(#rs-skylight)" />
      <path d="M506 340l62-58" stroke="#f4fbfc" stroke-opacity=".55" stroke-width="7" stroke-linecap="round" />
      <path d="M524 344l50-47" stroke="#f4fbfc" stroke-opacity=".3" stroke-width="4" stroke-linecap="round" />
    </g>

    <!-- First -->
    <rect x="86" y="196" width="628" height="22" rx="10" fill="#2e2a26" />
    <rect x="86" y="200" width="628" height="4" rx="2" fill="#8a7f72" opacity=".5" />

    <!-- Traufe und Rinne -->
    <rect x="64" y="512" width="672" height="20" rx="10" fill="#3a3631" />
    <rect x="66" y="515" width="668" height="3.5" rx="1.75" fill="#9b9184" opacity=".55" />
    <path d="M714 532v158" stroke="#3a3631" stroke-width="13" stroke-linecap="round" />
    <path d="M714 552h0" stroke="#9b9184" stroke-width="4" />

    <!-- Hauswand mit warm beleuchteten Fenstern -->
    <rect x="96" y="532" width="608" height="160" fill="url(#rs-wall)" />
    <g>
      <rect x="160" y="566" width="118" height="126" rx="4" fill="#f7f1e6" />
      <rect x="169" y="575" width="100" height="117" fill="url(#rs-window-glow)" />
      <path d="M219 575v117M169 632h100" stroke="#f7f1e6" stroke-width="7" />
      <rect x="152" y="686" width="134" height="10" rx="4" fill="#c8b291" />
    </g>
    <g>
      <rect x="452" y="566" width="118" height="126" rx="4" fill="#f7f1e6" />
      <rect x="461" y="575" width="100" height="117" fill="url(#rs-window-glow)" />
      <path d="M511 575v117M461 632h100" stroke="#f7f1e6" stroke-width="7" />
      <rect x="444" y="686" width="134" height="10" rx="4" fill="#c8b291" />
    </g>

    <!-- Tropfen an der Rinne während der Reinigung -->
    <g class="rs-drips">
      <path class="rs-drip rs-drip-1" d="M320 538c0 6 8 8 8 14a8 8 0 1 1-16 0c0-6 8-8 8-14Z" fill="#9fd4e8" opacity=".85" />
      <path class="rs-drip rs-drip-2" d="M398 538c0 6 8 8 8 14a8 8 0 1 1-16 0c0-6 8-8 8-14Z" fill="#9fd4e8" opacity=".85" />
      <path class="rs-drip rs-drip-3" d="M620 538c0 6 8 8 8 14a8 8 0 1 1-16 0c0-6 8-8 8-14Z" fill="#9fd4e8" opacity=".85" />
    </g>

    <!-- Hochdruck-Lanze, folgt der Reinigungsbahn -->
    <g class="rs-lance">
      <g class="rs-lance-art">
        <ellipse cx="0" cy="0" rx="46" ry="40" fill="#cdeef7" opacity=".38" filter="url(#rs-soft)" />
        <g class="rs-jet">
          <path d="M-3 -3 L-40 -30 M0 -5 L-12 -46 M3 -3 L40 -30 M-6 0 L-52 -6 M6 0 L52 -6" stroke="#e9fbff" stroke-width="4.5" stroke-linecap="round" opacity=".9" />
          <circle cx="-46" cy="-22" r="4" fill="#d3f1fa" />
          <circle cx="-20" cy="-42" r="3.2" fill="#e9fbff" />
          <circle cx="20" cy="-42" r="3.2" fill="#e9fbff" />
          <circle cx="46" cy="-22" r="4" fill="#d3f1fa" />
          <circle cx="-56" cy="-2" r="2.8" fill="#d3f1fa" />
          <circle cx="56" cy="-2" r="2.8" fill="#d3f1fa" />
        </g>
        <path d="M2 2 L64 66" stroke="url(#rs-metal)" stroke-width="9" stroke-linecap="round" />
        <path d="M0 0 L14 14" stroke="#2e2a26" stroke-width="13" stroke-linecap="round" />
        <path d="M46 48 L78 80" stroke="#2e2a26" stroke-width="15" stroke-linecap="round" />
        <path d="M78 80q22 10 26 34" fill="none" stroke="#2e2a26" stroke-width="8" stroke-linecap="round" />
        <circle cx="0" cy="0" r="7" fill="#d45f2e" stroke="#2e2a26" stroke-width="3" />
      </g>
    </g>

    <!-- Glanzpunkte nach der Reinigung -->
    <g class="rs-sparkles" fill="#fff8ef">
      <path class="rs-sparkle rs-sparkle-1" d="M236 306l4 12 12 4-12 4-4 12-4-12-12-4 12-4Z" />
      <path class="rs-sparkle rs-sparkle-2" d="M420 258l3.5 10 10 3.5-10 3.5-3.5 10-3.5-10-10-3.5 10-3.5Z" />
      <path class="rs-sparkle rs-sparkle-3" d="M330 436l3.5 10 10 3.5-10 3.5-3.5 10-3.5-10-10-3.5 10-3.5Z" />
      <path class="rs-sparkle rs-sparkle-4" d="M624 420l3 9 9 3-9 3-3 9-3-9-9-3 9-3Z" />
    </g>
  </g>
</svg>

<style>
  .roof-scene {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Master-Zyklus: 14s. Reinigung ca. 8–60 %, Glanz bis 90 %, dann Reset. */
  .rs-reveal-stroke {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    animation: rs-reveal 14s linear infinite;
  }

  .rs-clean-layer {
    animation: rs-clean-fade 14s linear infinite;
  }

  /* Nach der letzten Bahn deckt die Vollfläche auch die Kurven-Ecken ab. */
  .rs-mask-fill {
    opacity: 0;
    animation: rs-mask-fill 14s linear infinite;
  }

  @keyframes rs-mask-fill {
    0%, 58% { opacity: 0; }
    64%, 100% { opacity: 1; }
  }

  .rs-lance {
    offset-path: path('M158 262 H612 Q654 262 654 304 V322 Q654 364 612 364 H182 Q140 364 140 406 V424 Q140 466 182 466 H716');
    offset-rotate: 0deg;
    animation: rs-lance-travel 14s linear infinite;
  }

  @supports not (offset-path: path('M0 0L1 1')) {
    .rs-lance { display: none; }
  }

  .rs-lance-art { animation: rs-lance-bob 1.1s ease-in-out infinite alternate; }

  .rs-jet path { stroke-dasharray: 10 9; animation: rs-jet-flow .4s linear infinite; }

  .rs-drips { animation: rs-drips-window 14s linear infinite; }
  .rs-drip { animation: rs-drip-fall 1.7s ease-in infinite; }
  .rs-drip-2 { animation-delay: .55s; }
  .rs-drip-3 { animation-delay: 1.05s; }

  .rs-sparkles { animation: rs-sparkles-window 14s linear infinite; }
  .rs-sparkle { transform-box: fill-box; transform-origin: center; animation: rs-twinkle 2.4s ease-in-out infinite; }
  .rs-sparkle-2 { animation-delay: .5s; }
  .rs-sparkle-3 { animation-delay: 1s; }
  .rs-sparkle-4 { animation-delay: 1.6s; }

  .rs-smoke { stroke-dasharray: 40; animation: rs-smoke-drift 3.2s ease-out infinite; }
  .rs-smoke-2 { animation-delay: 1.4s; }

  @keyframes rs-reveal {
    0%, 8% { stroke-dashoffset: 100; }
    60% { stroke-dashoffset: 0; }
    100% { stroke-dashoffset: 0; }
  }

  @keyframes rs-clean-fade {
    0%, 88% { opacity: 1; }
    96%, 100% { opacity: 0; }
  }

  @keyframes rs-lance-travel {
    0%, 8% { offset-distance: 0%; opacity: 0; }
    10.5% { opacity: 1; }
    58% { opacity: 1; }
    60% { offset-distance: 100%; opacity: 0; }
    100% { offset-distance: 100%; opacity: 0; }
  }

  @keyframes rs-lance-bob {
    from { transform: translateY(-2.5px); }
    to { transform: translateY(2.5px); }
  }

  @keyframes rs-jet-flow {
    to { stroke-dashoffset: -19; }
  }

  @keyframes rs-drips-window {
    0%, 12% { opacity: 0; }
    16%, 60% { opacity: 1; }
    66%, 100% { opacity: 0; }
  }

  @keyframes rs-drip-fall {
    0% { transform: translateY(0); opacity: 0; }
    18% { opacity: .9; }
    100% { transform: translateY(64px); opacity: 0; }
  }

  @keyframes rs-sparkles-window {
    0%, 24% { opacity: 0; }
    30%, 88% { opacity: 1; }
    94%, 100% { opacity: 0; }
  }

  @keyframes rs-twinkle {
    0%, 100% { opacity: 0; transform: scale(.4) rotate(0deg); }
    50% { opacity: .95; transform: scale(1) rotate(20deg); }
  }

  @keyframes rs-smoke-drift {
    0% { stroke-dashoffset: 40; opacity: 0; }
    30% { opacity: .7; }
    100% { stroke-dashoffset: -12; opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .roof-scene *, .roof-scene { animation: none !important; }
    .rs-reveal-stroke { stroke-dashoffset: 46; }
    .rs-lance { display: none; }
    .rs-drips { opacity: 0; }
    .rs-sparkles { opacity: 1; }
    .rs-sparkle { opacity: .8; transform: none; }
  }
</style>
