---
import BodenseeMark from './BodenseeMark.astro';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <a class="footer-brand" href="/">AR Holz- &amp; Bautenschutz</a>
      <p>Holzschutz, Bautenschutz, Abdichtungen, Dachservice sowie Fenster- und Gewächshausreinigung – mit Sitz in Konstanz, im Einsatz in der ganzen Bodensee-Region.</p>
      <div class="footer-lake">
        <BodenseeMark />
        <span>Konstanz · Bodensee</span>
      </div>
    </div>
    <div>
      <span class="footer-label">Kontakt</span>
      <a href="tel:+491772156157">+49 177 2156157</a>
      <a href="mailto:AR.Holzschutz@web.de">AR.Holzschutz@web.de</a>
      <a href="https://wa.me/491772156157?text=Hallo%20Herr%20Razai%2C%20ich%20m%C3%B6chte%20gerne%20eine%20unverbindliche%20Anfrage%20stellen.">Per WhatsApp schreiben</a>
    </div>
    <div>
      <span class="footer-label">Anschrift</span>
      <p>Aref Razai<br />Bücklestraße 9 A<br />78467 Konstanz</p>
    </div>
    <div>
      <span class="footer-label">Rechtliches</span>
      <a href="/impressum/">Impressum</a>
      <a href="/datenschutz/">Datenschutz</a>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>© {new Date().getFullYear()} AR Holz- &amp; Bautenschutz</span>
    <span class="visit-counter" data-visit-counter hidden>
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M2.5 12S6 5.8 12 5.8 21.5 12 21.5 12 18 18.2 12 18.2 2.5 12 2.5 12Z" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/><circle cx="12" cy="12" r="2.7" fill="none" stroke="currentColor" stroke-width="1.7"/></svg>
      <span data-count>–</span>&nbsp;Aufrufe
    </span>
    <span>Persönlich geführt von Aref Razai</span>
  </div>
</footer>

<script>
  const counter = document.querySelector('[data-visit-counter]');
  const countTarget = counter?.querySelector('[data-count]');

  if (counter instanceof HTMLElement && countTarget) {
    const alreadyCounted = sessionStorage.getItem('ar-dach-counted') === '1';
    const endpoint = alreadyCounted ? 'get' : 'hit';

    fetch(`https://abacus.jasoncameron.dev/${endpoint}/ar-dach-de/visits`)
      .then((response) => (response.ok ? response.json() : Promise.reject()))
      .then((data) => {
        const value = typeof data.value === 'number' ? data.value : null;
        if (value === null) return;
        countTarget.textContent = value.toLocaleString('de-DE');
        counter.hidden = false;
        sessionStorage.setItem('ar-dach-counted', '1');
      })
      .catch(() => {
        /* Zähler nicht erreichbar – Element bleibt ausgeblendet. */
      });
  }
</script>
