        <path d="m448 357 6 13-8 6" fill="none" stroke="#242423" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M475 359c-8 1-14 5-20 11" fill="none" stroke="#292826" stroke-width="6" stroke-linecap="round" />
