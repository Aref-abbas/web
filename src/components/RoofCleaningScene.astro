---
interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
const sceneId = `roof-scene-${Math.random().toString(36).slice(2, 9)}`;
---

<div
  class:list={['roof-cleaning-scene', className]}
  data-roof-cleaning-scene
  data-state="idle"
  aria-hidden="true"
>
  <svg class="scene-art" viewBox="0 0 800 720" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    <defs>
      <linearGradient id={`${sceneId}-paper`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#faf6ef" />
        <stop offset=".52" stop-color="#efe7da" />
        <stop offset="1" stop-color="#dfd3c3" />
      </linearGradient>
      <linearGradient id={`${sceneId}-roof`} x1=".08" y1=".05" x2=".92" y2=".95">
        <stop offset="0" stop-color="#66544c" />
        <stop offset=".48" stop-color="#4b403c" />
        <stop offset="1" stop-color="#302c2a" />
      </linearGradient>
      <linearGradient id={`${sceneId}-clean`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#a6755f" />
        <stop offset=".48" stop-color="#bd7657" />
        <stop offset="1" stop-color="#774f43" />
      </linearGradient>
      <linearGradient id={`${sceneId}-wall`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#d9c9b5" />
        <stop offset="1" stop-color="#a89680" />
      </linearGradient>
      <linearGradient id={`${sceneId}-wall-side`} x1="0" y1="0" x2="1" y2="1">
        <stop offset="0" stop-color="#af9e89" />
        <stop offset="1" stop-color="#74695e" />
      </linearGradient>
      <linearGradient id={`${sceneId}-water`} x1="0" y1="0" x2="1" y2="0">
        <stop offset="0" stop-color="#f7ffff" stop-opacity=".95" />
        <stop offset=".52" stop-color="#a6def0" stop-opacity=".86" />
        <stop offset="1" stop-color="#eaffff" stop-opacity=".18" />
      </linearGradient>
      <radialGradient id={`${sceneId}-glow`} cx="50%" cy="45%" r="60%">
        <stop offset="0" stop-color="#fff" stop-opacity=".92" />
        <stop offset=".35" stop-color="#d9f5ff" stop-opacity=".7" />
        <stop offset="1" stop-color="#a7ddec" stop-opacity="0" />
      </radialGradient>
      <pattern id={`${sceneId}-grid`} width="38" height="38" patternUnits="userSpaceOnUse">
        <path d="M38 0H0V38" fill="none" stroke="#171715" stroke-opacity=".055" stroke-width="1" />
      </pattern>
      <pattern id={`${sceneId}-tiles`} width="52" height="34" patternUnits="userSpaceOnUse" patternTransform="skewY(7)">
        <path d="M0 1h52M0 33h52" fill="none" stroke="#171715" stroke-opacity=".42" stroke-width="2" />
        <path d="M6 1v14c0 8 7 14 20 14s20-6 20-14V1" fill="none" stroke="#211e1c" stroke-opacity=".58" stroke-width="2.2" />
        <path d="M10 5v10c0 6 5 10 16 10s16-4 16-10V5" fill="none" stroke="#f3d8c7" stroke-opacity=".1" stroke-width="1.2" />
      </pattern>
      <pattern id={`${sceneId}-clean-tiles`} width="52" height="34" patternUnits="userSpaceOnUse" patternTransform="skewY(7)">
        <rect width="52" height="34" fill={`url(#${sceneId}-clean)`} />
        <path d="M0 1h52M0 33h52" fill="none" stroke="#5f372d" stroke-opacity=".52" stroke-width="2" />
        <path d="M6 1v14c0 8 7 14 20 14s20-6 20-14V1" fill="none" stroke="#5b342c" stroke-opacity=".72" stroke-width="2.2" />
        <path d="M10 5v10c0 6 5 10 16 10s16-4 16-10V5" fill="none" stroke="#ffe1d0" stroke-opacity=".22" stroke-width="1.2" />
      </pattern>
      <clipPath id={`${sceneId}-roof-clip`}>
        <path d="M77 372 377 188 724 379 405 575Z" />
      </clipPath>
      <filter id={`${sceneId}-shadow`} x="-30%" y="-30%" width="160%" height="180%">
        <feDropShadow dx="0" dy="24" stdDeviation="22" flood-color="#171715" flood-opacity=".22" />
      </filter>
      <filter id={`${sceneId}-soft`} x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="8" />
      </filter>
      <filter id={`${sceneId}-mist`} x="-60%" y="-60%" width="220%" height="220%">
        <feGaussianBlur stdDeviation="3.5" />
      </filter>
    </defs>

    <rect width="800" height="720" fill={`url(#${sceneId}-paper)`} />
    <rect class="scene-grid" width="800" height="720" fill={`url(#${sceneId}-grid)`} />
