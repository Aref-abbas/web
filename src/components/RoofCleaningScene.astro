<style>
  .roof-cleaning-scene {
    --scene-accent: var(--roof-scene-accent, #d45f2e);
    --scene-ink: var(--roof-scene-ink, #171715);
    --scene-paper: var(--roof-scene-paper, #f4f0e8);
    --scene-radius: var(--roof-scene-radius, 120px 14px 14px 14px);
    --scene-height: var(--roof-scene-min-height, clamp(500px, 50vw, 650px));
    position: relative;
    isolation: isolate;
    width: 100%;
    height: 100%;
    min-height: var(--scene-height);
    overflow: hidden;
    border-radius: var(--scene-radius);
    background: var(--scene-paper);
    color: var(--scene-ink);
    box-shadow: 0 24px 60px rgba(18, 17, 15, .12);
  }

  .scene-art,
  .water-glass,
  .scene-vignette {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .scene-art {
    z-index: 1;
    color: var(--scene-ink);
  }

  .scene-grid { mix-blend-mode: multiply; }
  .scene-sun { fill: var(--scene-accent); }
  .scene-label circle { fill: var(--scene-accent); }

  .roof-model {
    transform-origin: 50% 58%;
    transform-box: fill-box;
  }

  .scene-sun-ring,
  .scene-route,
  .scene-atmosphere,
  .roof-model,
  .scene-label {
    transition: opacity .4s ease;
  }

  .worker {
    transform-origin: 50% 88%;
    transform-box: fill-box;
  }

  .worker-leg {
    transform-origin: 50% 5%;
    transform-box: fill-box;
  }

  .cleaning-feather,
  .cleaning-pass,
  .wet-pass {
    stroke-dasharray: 240;
    stroke-dashoffset: 0;
  }

  .water-jet { opacity: .86; }
  .runoff-streaks { opacity: 0; }
  .screen-burst { opacity: 0; transform-origin: center; }

  .water-glass {
    position: fixed;
    z-index: 95;
    width: 100vw;
    height: 100dvh;
    display: block;
    pointer-events: none;
    opacity: 0;
    transition: opacity .28s ease;
  }

  .scene-vignette {
    z-index: 6;
    pointer-events: none;
    border: 1px solid rgba(23, 23, 21, .08);
    border-radius: inherit;
    background:
      linear-gradient(130deg, rgba(255, 255, 255, .3), transparent 22%),
      linear-gradient(to top, rgba(23, 23, 21, .09), transparent 28%);
    box-shadow: inset 0 0 80px rgba(23, 23, 21, .05);
  }

  .roof-cleaning-scene.is-enhanced:not(.is-playing) .cleaning-pass,
  .roof-cleaning-scene.is-enhanced:not(.is-playing) .cleaning-feather,
  .roof-cleaning-scene.is-enhanced:not(.is-playing) .wet-pass {
    stroke-dashoffset: 240;
  }

  .roof-cleaning-scene.is-enhanced:not(.is-playing) .water-jet { opacity: 0; }

  .roof-cleaning-scene.is-playing .roof-model {
    animation: roof-arrival 1.15s cubic-bezier(.2, .76, .2, 1) both;
  }

  .roof-cleaning-scene.is-playing .worker {
    animation: worker-route 8s cubic-bezier(.44, .04, .24, 1) both;
  }

  .roof-cleaning-scene.is-playing .worker-leg-front {
    animation: step-front .56s ease-in-out 4 alternate 1.05s;
  }

  .roof-cleaning-scene.is-playing .worker-leg-back {
    animation: step-back .56s ease-in-out 4 alternate 1.05s;
  }

  .roof-cleaning-scene.is-playing .cleaning-pass,
  .roof-cleaning-scene.is-playing .cleaning-feather {
    animation: clean-reveal 8s cubic-bezier(.24, .68, .18, 1) both;
  }

  .roof-cleaning-scene.is-playing .runoff-streaks {
    animation: runoff-reveal 8s ease both;
  }

  .roof-cleaning-scene.is-playing .wet-pass {
    animation: wet-reveal 8s cubic-bezier(.24, .68, .18, 1) both;
  }

  .roof-cleaning-scene.is-playing .water-jet {
    animation: jet-cycle 8s ease both;
  }

  .roof-cleaning-scene.is-playing .jet-core {
    animation: water-flow .36s linear 12 1.2s;
  }

  .roof-cleaning-scene.is-playing .screen-burst {
    animation: viewer-splash 8s cubic-bezier(.18, .72, .26, 1) both;
  }

  .water-glass.is-visible { opacity: 1; }
  .water-glass.is-cleared { opacity: 0; }

  @keyframes roof-arrival {
    from { opacity: 0; transform: translateY(22px) scale(.965); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes worker-route {
    0%, 9% { transform: translate(42px, -20px) scale(.96); }
    21% { transform: translate(23px, -10px) rotate(-1deg); }
    36% { transform: translate(2px, 2px) rotate(1.5deg); }
    52%, 61% { transform: translate(-20px, 14px) rotate(-1deg); }
    68% { transform: translate(-15px, 10px) rotate(2deg); }
    74%, 100% { transform: translate(-9px, 6px) rotate(0); }
  }

  @keyframes step-front {
    from { transform: rotate(3deg) translateY(-.5px); }
    to { transform: rotate(-6deg) translateY(.5px); }
  }

  @keyframes step-back {
    from { transform: rotate(-4deg) translateY(.5px); }
    to { transform: rotate(6deg) translateY(-.5px); }
  }

  @keyframes clean-reveal {
    0%, 14% { stroke-dashoffset: 240; }
    58%, 100% { stroke-dashoffset: 0; }
  }

  @keyframes wet-reveal {
    0%, 14% { stroke-dashoffset: 240; opacity: 0; }
    24% { opacity: .8; }
    58% { stroke-dashoffset: 0; opacity: .58; }
    82%, 100% { stroke-dashoffset: 0; opacity: .16; }
  }

  @keyframes runoff-reveal {
    0%, 30% { opacity: 0; }
    44%, 66% { opacity: .9; }
    86%, 100% { opacity: .26; }
  }

  @keyframes jet-cycle {
    0%, 13% { opacity: 0; }
    17%, 57% { opacity: .94; }
    61%, 100% { opacity: 0; }
  }

  @keyframes water-flow {
    to { stroke-dashoffset: -30; }
  }

  @keyframes viewer-splash {
    0%, 62% { opacity: 0; transform: translate(398px, 363px) scale(.08); }
    66% { opacity: .94; transform: translate(398px, 363px) scale(.42); }
    72% { opacity: .48; transform: translate(398px, 363px) scale(2.45); }
    78%, 100% { opacity: 0; transform: translate(398px, 363px) scale(3.05); }
  }

  @media (max-width: 640px) {
    .roof-cleaning-scene {
      --scene-radius: var(--roof-scene-radius, 72px 12px 12px 12px);
      --scene-height: var(--roof-scene-min-height, clamp(400px, 118vw, 540px));
    }

    .scene-art { transform: scale(1.035); }
    .scene-atmosphere, .scene-route, .scene-corner-mark { display: none; }
    .scene-grid { opacity: .6; }
    .scene-label { transform: translate(22px, 18px) scale(.9); transform-origin: left top; }
    .roof-weathering circle:nth-of-type(n + 2) { display: none; }
    .washer-unit { opacity: .9; }

    .roof-cleaning-scene.is-playing .worker {
      animation-duration: 6.8s;
    }

    .roof-cleaning-scene.is-playing .cleaning-pass,
    .roof-cleaning-scene.is-playing .cleaning-feather,
    .roof-cleaning-scene.is-playing .wet-pass,
    .roof-cleaning-scene.is-playing .runoff-streaks,
    .roof-cleaning-scene.is-playing .water-jet,
    .roof-cleaning-scene.is-playing .screen-burst {
      animation-duration: 6.8s;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .roof-cleaning-scene *,
    .roof-cleaning-scene *::before,
    .roof-cleaning-scene *::after {
      animation: none !important;
      transition: none !important;
    }

    .roof-cleaning-scene .screen-burst,
    .water-glass { display: none; }

    .roof-cleaning-scene .water-jet { opacity: .52; }
    .roof-cleaning-scene .runoff-streaks { opacity: .22; }
    .roof-cleaning-scene .wet-pass { opacity: .2; }
  }
</style>

<script>
  type Droplet = {
    x: number;
    y: number;
    radius: number;
    stretch: number;
    rotation: number;
    opacity: number;
    tail: number;
    wobble: number;
  };

  const sceneRoots = document.querySelectorAll('[data-roof-cleaning-scene]:not([data-roof-scene-ready])');

  sceneRoots.forEach((sceneRoot) => {
    if (!(sceneRoot instanceof HTMLElement)) return;

    const canvas = sceneRoot.querySelector('[data-roof-scene-canvas]');
    if (!(canvas instanceof HTMLCanvasElement)) return;

    sceneRoot.dataset.roofSceneReady = 'true';

    const context = canvas.getContext('2d');
    const filmCanvas = document.createElement('canvas');
    const filmContext = filmCanvas.getContext('2d');

    if (!context || !filmContext) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    const compactScene = window.matchMedia('(max-width: 640px)');
    const abortController = new AbortController();
    const timers = new Set<number>();
    const supportsIntersectionObserver = typeof globalThis.IntersectionObserver !== 'undefined';
    let observer: IntersectionObserver | undefined;
    let animationFrame = 0;
    let splashStart = 0;
    let splashScrollPosition = 0;
    let wipeProgress = 0;
    let hasStarted = false;
    let hasSplashed = false;
    let isDisposed = false;
    let sceneWidth = 0;
    let sceneHeight = 0;
    let pixelRatio = 1;
    let droplets: Droplet[] = [];

    const clamp = (value: number, minimum: number, maximum: number) => Math.min(Math.max(value, minimum), maximum);
    const easeOut = (value: number) => 1 - Math.pow(1 - value, 3);

    const schedule = (callback: () => void, delay: number) => {
      const timer = window.setTimeout(() => {
        timers.delete(timer);
        callback();
      }, delay);
      timers.add(timer);
      return timer;
    };

    const clearTimers = () => {
      timers.forEach((timer) => window.clearTimeout(timer));
      timers.clear();
    };

    const seededNumber = (seed: number) => {
      const value = Math.sin(seed * 9283.17) * 43758.5453;
      return value - Math.floor(value);
    };

    const buildDroplets = () => {
      const dropletCount = compactScene.matches ? 14 : 24;
      droplets = Array.from({ length: dropletCount }, (_, index) => {
        const sizeSeed = seededNumber(index + 14);
        const radius = 2 + sizeSeed * sizeSeed * (compactScene.matches ? 13 : 21);
        return {
          x: .05 + seededNumber(index + 31) * .9,
          y: .04 + seededNumber(index + 67) * .9,
          radius,
          stretch: .8 + seededNumber(index + 103) * .58,
          rotation: -.7 + seededNumber(index + 149) * 1.4,
          opacity: .28 + seededNumber(index + 191) * .34,
          tail: seededNumber(index + 227),
          wobble: .82 + seededNumber(index + 263) * .36,
        };
      });
    };

    const resizeCanvas = () => {
      sceneWidth = Math.max(1, Math.round(window.innerWidth));
      sceneHeight = Math.max(1, Math.round(window.innerHeight));
      pixelRatio = Math.min(window.devicePixelRatio || 1, compactScene.matches ? 1.5 : 2);

      canvas.width = Math.round(sceneWidth * pixelRatio);
      canvas.height = Math.round(sceneHeight * pixelRatio);
      filmCanvas.width = canvas.width;
      filmCanvas.height = canvas.height;
      buildDroplets();

      if (hasSplashed) renderFilm(performance.now());
    };

    const paintDroplet = (drawingContext: CanvasRenderingContext2D, droplet: Droplet, arrival: number) => {
      const centerX = sceneWidth * .5;
      const centerY = sceneHeight * .48;
      const targetX = droplet.x * sceneWidth;
      const targetY = droplet.y * sceneHeight;
      const x = centerX + (targetX - centerX) * arrival;
      const y = centerY + (targetY - centerY) * arrival;
      const radius = droplet.radius * (.15 + arrival * .85);

      drawingContext.save();
      drawingContext.translate(x, y);
      drawingContext.rotate(droplet.rotation);
      drawingContext.scale(1, droplet.stretch);
      drawingContext.shadowColor = `rgba(52, 91, 101, ${droplet.opacity * .24})`;
      drawingContext.shadowBlur = Math.max(2, radius * .24);
      drawingContext.shadowOffsetY = Math.max(1, radius * .08);

      const dropletGradient = drawingContext.createRadialGradient(
        -radius * .32,
        -radius * .38,
        radius * .08,
        0,
        0,
        radius,
      );
      dropletGradient.addColorStop(0, `rgba(255, 255, 255, ${droplet.opacity * .92})`);
      dropletGradient.addColorStop(.18, `rgba(221, 247, 252, ${droplet.opacity * .46})`);
      dropletGradient.addColorStop(.72, `rgba(127, 190, 207, ${droplet.opacity * .14})`);
      dropletGradient.addColorStop(1, 'rgba(71, 125, 142, 0)');

      drawingContext.beginPath();
      drawingContext.moveTo(0, -radius);
      drawingContext.bezierCurveTo(
        radius * .72 * droplet.wobble,
        -radius * .84,
        radius * 1.02,
        -radius * .08,
        radius * .74,
        radius * .66,
      );
      drawingContext.bezierCurveTo(
        radius * .38,
        radius * 1.03,
        -radius * .48,
        radius * .98,
        -radius * .78,
        radius * .5,
      );
      drawingContext.bezierCurveTo(
        -radius * 1.02,
        radius * .08,
        -radius * .62 * droplet.wobble,
        -radius * .82,
        0,
        -radius,
      );
      drawingContext.closePath();
      drawingContext.fillStyle = dropletGradient;
      drawingContext.fill();
      drawingContext.shadowColor = 'transparent';
      drawingContext.strokeStyle = `rgba(238, 253, 255, ${droplet.opacity * .52})`;
      drawingContext.lineWidth = Math.max(.8, radius * .045);
      drawingContext.stroke();

      drawingContext.beginPath();
      drawingContext.ellipse(-radius * .3, -radius * .38, radius * .18, radius * .075, -.5, 0, Math.PI * 2);
      drawingContext.fillStyle = `rgba(255, 255, 255, ${droplet.opacity * .78})`;
      drawingContext.fill();

      drawingContext.beginPath();
      drawingContext.ellipse(radius * .14, radius * .28, radius * .48, radius * .2, .08, 0, Math.PI);
      drawingContext.strokeStyle = `rgba(52, 100, 113, ${droplet.opacity * .18})`;
      drawingContext.lineWidth = Math.max(.7, radius * .035);
      drawingContext.stroke();

      if (droplet.tail > .72) {
        const tailLength = radius * (1.1 + droplet.tail * 1.8);
        const tailGradient = drawingContext.createLinearGradient(0, radius * .6, 0, tailLength);
        tailGradient.addColorStop(0, `rgba(214, 244, 250, ${droplet.opacity * .28})`);
        tailGradient.addColorStop(1, 'rgba(214, 244, 250, 0)');
        drawingContext.beginPath();
        drawingContext.moveTo(radius * .08, radius * .62);
        drawingContext.quadraticCurveTo(radius * .2, tailLength * .62, -radius * .04, tailLength);
        drawingContext.strokeStyle = tailGradient;
        drawingContext.lineWidth = Math.max(1, radius * .16);
        drawingContext.lineCap = 'round';
        drawingContext.stroke();
      }
      drawingContext.restore();
    };

    const paintFilm = (arrival: number) => {
      filmContext.setTransform(1, 0, 0, 1, 0, 0);
      filmContext.clearRect(0, 0, filmCanvas.width, filmCanvas.height);
      filmContext.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0);

      const filmGradient = filmContext.createLinearGradient(0, 0, sceneWidth, sceneHeight);
      filmGradient.addColorStop(0, `rgba(225, 248, 252, ${.1 * arrival})`);
      filmGradient.addColorStop(.38, `rgba(177, 222, 233, ${.055 * arrival})`);
      filmGradient.addColorStop(.72, `rgba(244, 253, 252, ${.12 * arrival})`);
      filmGradient.addColorStop(1, `rgba(110, 176, 193, ${.075 * arrival})`);
      filmContext.fillStyle = filmGradient;
      filmContext.fillRect(0, 0, sceneWidth, sceneHeight);

      droplets.forEach((droplet) => paintDroplet(filmContext, droplet, arrival));

      if (wipeProgress <= 0) return;
      if (wipeProgress >= .999) {
        filmContext.clearRect(0, 0, sceneWidth, sceneHeight);
        return;
      }

      const softness = Math.max(42, sceneHeight * .1);
      const sweepPosition = -sceneHeight * .74 + wipeProgress * sceneHeight * 1.56;
      const topEdge = -sceneHeight * 1.2;

      filmContext.save();
      filmContext.globalCompositeOperation = 'destination-out';
      filmContext.translate(sceneWidth / 2, sceneHeight / 2);
      filmContext.rotate(-.095);

      const solidHeight = Math.max(0, sweepPosition - softness - topEdge);
      filmContext.fillStyle = '#000';
      filmContext.fillRect(-sceneWidth, topEdge, sceneWidth * 2, solidHeight);

      const softMask = filmContext.createLinearGradient(0, sweepPosition - softness, 0, sweepPosition + softness);
      softMask.addColorStop(0, 'rgba(0, 0, 0, 1)');
      softMask.addColorStop(.56, 'rgba(0, 0, 0, .8)');
      softMask.addColorStop(1, 'rgba(0, 0, 0, 0)');
      filmContext.fillStyle = softMask;
      filmContext.fillRect(-sceneWidth, sweepPosition - softness, sceneWidth * 2, softness * 2);
      filmContext.restore();
    };

    const drawWipeEdge = () => {
      if (wipeProgress <= .015 || wipeProgress >= .985) return;

      const edgeY = -sceneHeight * .24 + wipeProgress * sceneHeight * 1.38;
      context.save();
      context.setTransform(pixelRatio, 0, 0, pixelRatio, 0, 0);
      context.translate(sceneWidth / 2, sceneHeight / 2);
      context.rotate(-.095);
      const edgeGradient = context.createLinearGradient(-sceneWidth * .5, 0, sceneWidth * .5, 0);
      edgeGradient.addColorStop(0, 'rgba(235, 252, 255, 0)');
      edgeGradient.addColorStop(.2, 'rgba(235, 252, 255, .42)');
      edgeGradient.addColorStop(.8, 'rgba(235, 252, 255, .32)');
      edgeGradient.addColorStop(1, 'rgba(235, 252, 255, 0)');
      context.strokeStyle = edgeGradient;
      context.lineWidth = 2;
      context.beginPath();
      context.moveTo(-sceneWidth * .62, edgeY);
      context.bezierCurveTo(-sceneWidth * .2, edgeY + 8, sceneWidth * .16, edgeY - 10, sceneWidth * .62, edgeY + 2);
      context.stroke();
      context.restore();
    };

    const renderFilm = (time: number) => {
      if (!hasSplashed || isDisposed) return;

      const elapsed = clamp((time - splashStart) / 620, 0, 1);
      const arrival = easeOut(elapsed);
      paintFilm(arrival);

      context.setTransform(1, 0, 0, 1, 0, 0);
      context.clearRect(0, 0, canvas.width, canvas.height);
      context.drawImage(filmCanvas, 0, 0);
      drawWipeEdge();

      if (elapsed < 1) animationFrame = window.requestAnimationFrame(renderFilm);
    };

    const requestFilmRender = () => {
      window.cancelAnimationFrame(animationFrame);
      animationFrame = window.requestAnimationFrame(renderFilm);
    };

    const showSplash = () => {
      if (isDisposed || reducedMotion.matches) return;
      const bounds = sceneRoot.getBoundingClientRect();
      const sceneIsVisible = bounds.bottom > 0 && bounds.top < window.innerHeight * .78;

      if (!sceneIsVisible) {
        sceneRoot.dataset.state = 'cleared';
        sceneRoot.classList.add('is-cleared');
        return;
      }

      hasSplashed = true;
      splashStart = performance.now();
      splashScrollPosition = window.scrollY;
      sceneRoot.dataset.state = 'splashed';
      sceneRoot.classList.add('is-splashed');
      canvas.classList.add('is-visible');
      requestFilmRender();
    };

    const startScene = () => {
      if (hasStarted || reducedMotion.matches || isDisposed) return;
      hasStarted = true;
      sceneRoot.dataset.state = 'cleaning';
      sceneRoot.classList.add('is-playing');
      const splashDelay = compactScene.matches ? 4450 : 5150;
      schedule(showSplash, splashDelay);
    };

    const handleScroll = () => {
      if (!hasSplashed || wipeProgress >= 1 || reducedMotion.matches) return;
      const wipeDistance = clamp(window.innerHeight * .58, 280, 560);
      const nextProgress = clamp((window.scrollY - splashScrollPosition) / wipeDistance, 0, 1);
      if (nextProgress <= wipeProgress) return;

      wipeProgress = nextProgress;
      sceneRoot.style.setProperty('--roof-scene-wipe-progress', wipeProgress.toFixed(3));
      requestFilmRender();

      if (wipeProgress >= .999) {
        sceneRoot.dataset.state = 'cleared';
        sceneRoot.classList.add('is-cleared');
        canvas.classList.add('is-cleared');
      }
    };

    const enableMotion = () => {
      sceneRoot.classList.remove('is-reduced');
      sceneRoot.classList.add('is-enhanced');

      if (supportsIntersectionObserver) {
        observer = new IntersectionObserver((entries) => {
          if (!entries.some((entry) => entry.isIntersecting && entry.intersectionRatio >= .32)) return;
          observer?.disconnect();
          startScene();
        }, { threshold: [.32] });
        observer.observe(sceneRoot);
      } else {
        animationFrame = window.requestAnimationFrame(startScene);
      }
    };

    const disableMotion = () => {
      observer?.disconnect();
      clearTimers();
      window.cancelAnimationFrame(animationFrame);
      hasStarted = false;
      hasSplashed = false;
      wipeProgress = 0;
      sceneRoot.dataset.state = 'reduced';
      sceneRoot.classList.remove('is-enhanced', 'is-playing', 'is-splashed', 'is-cleared');
      sceneRoot.classList.add('is-reduced');
      canvas.classList.remove('is-visible', 'is-cleared');
      context.clearRect(0, 0, canvas.width, canvas.height);
    };

    const handleMotionPreference = () => {
      if (reducedMotion.matches) disableMotion();
      else enableMotion();
    };

    const cleanup = () => {
      if (isDisposed) return;
      isDisposed = true;
      observer?.disconnect();
      abortController.abort();
      clearTimers();
      window.cancelAnimationFrame(animationFrame);
      reducedMotion.removeEventListener('change', handleMotionPreference);
      compactScene.removeEventListener('change', resizeCanvas);
      canvas.remove();
      sceneRoot.removeAttribute('data-roof-scene-ready');
    };

    resizeCanvas();
    document.body.append(canvas);
    window.addEventListener('resize', resizeCanvas, { passive: true, signal: abortController.signal });

    window.addEventListener('scroll', handleScroll, { passive: true, signal: abortController.signal });
    reducedMotion.addEventListener('change', handleMotionPreference);
    compactScene.addEventListener('change', resizeCanvas);
    document.addEventListener('astro:before-swap', cleanup, { once: true, signal: abortController.signal });
    handleMotionPreference();
  });
</script>
