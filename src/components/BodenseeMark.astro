---
// Stilisierte Bodensee-Silhouette (Obersee, Überlinger See, Untersee)
// mit Standort-Punkt bei Konstanz. Farbe über currentColor steuerbar.
interface Props {
  class?: string;
  dot?: boolean;
  dotColor?: string;
}

const { class: className = '', dot = true, dotColor = '#d45f2e' } = Astro.props;
---

<svg
  class:list={['bodensee-mark', className]}
  viewBox="6 8 228 122"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Bodensee-Silhouette mit Standort Konstanz"
>
  <path
    fill="currentColor"
    d="M58 16
       C66 26 80 40 96 52
       L96 56
       C93 56 90 56 88 56
       C80 52 72 48 66 50
       C58 42 48 34 43 38
       C40 41 44 47 42 52
       C36 58 24 68 14 78
       C10 81 10 84 13 84
       C18 84 24 80 30 76
       C42 70 54 66 66 64
       C76 62 86 62 94 64
       C98 65 100 66 102 68
       C120 84 148 100 178 112
       C196 120 214 126 223 122
       C229 119 230 113 226 108
       C220 100 202 88 178 78
       C154 66 132 58 114 52
       C108 50 105 49 102 46
       C92 36 78 24 66 16
       C62 13 58 13 58 16
       Z"
  />
  {dot && <circle cx="98" cy="58" r="8" fill={dotColor} />}
</svg>

<style>
  .bodensee-mark { display: block; }
</style>
